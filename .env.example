# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git

# ─── SMTP Email (for emergency alerts) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use a Gmail App Password — NOT your login password
# Generate at: Google Account → Security → 2-Step Verification → App passwords
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=your_email@gmail.com

# ─── CORS (for production deployment) ────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://your-app.vercel.app,https://your-custom-domain.com
# Leave empty for local development only (localhost:5173 is always allowed)
ALLOWED_ORIGINS=

# ─── Optional: Model download configuration ───────────────────────────────────
# Used by download_models.py if you host weights on Hugging Face Hub
# HF_TOKEN=your_huggingface_token_if_private_repo
